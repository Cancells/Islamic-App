<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="حديث اليوم"
            android:textColor="#E5C158"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نور"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20E5C158"
        android:layout_marginBottom="4dp" />

    <!-- Hadith Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="2dp">

        <TextView
            android:id="@+id/widget_hadith_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="إنما الأعمال بالنيات وإنما لكل امرئ ما نوى"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginBottom="2dp" />

        <TextView
            android:id="@+id/widget_hadith_ref"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="رواه البخاري ومسلم"
            android:textColor="#80E5C158"
            android:textSize="10sp"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>
</LinearLayout>
