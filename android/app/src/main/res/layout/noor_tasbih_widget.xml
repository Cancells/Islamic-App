<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="10dp">

    <!-- Header Row -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="السبحة الإلكترونية"
            android:textColor="#E5C158"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/widget_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="نور"
            android:textColor="#80FFFFFF"
            android:textSize="10sp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />
    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#20E5C158"
        android:layout_marginBottom="4dp" />

    <!-- Tasbih Content -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="2dp">

        <TextView
            android:id="@+id/widget_tasbih_dhikr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="سُبْحَانَ ٱللَّٰهِ"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/widget_tasbih_count_container"
            android:ellipsize="end"
            android:maxLines="1"
            android:paddingEnd="10dp" />

        <LinearLayout
            android:id="@+id/widget_tasbih_count_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/active_prayer_background"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/widget_tasbih_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 / 33"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
